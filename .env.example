# ============================================
# ReviewStem Configuration
# ============================================

# -------------------- Required --------------------

# OpenAI API key for LLM access
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# -------------------- Optional --------------------

# OpenAI model to use for reviews
# Default: gpt-4o-mini
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Note: Larger models provide better quality but cost more
# REVIEWSTEM_MODEL=gpt-4o-mini

# -------------------- Iteration Control --------------------

# Maximum number of mutation iterations per review
# Default: 2
# Range: 1-10
# Higher values allow more refinement but increase API costs
REVIEWSTEM_MAX_ITERATIONS=2

# Target fitness score to stop iteration early
# Default: 0.90
# Range: 0.0-1.0
# Reviews achieving this score will stop iterating early
REVIEWSTEM_TARGET_SCORE=0.90

# LLM temperature for review generation
# Default: 0
# Range: 0.0-2.0
# 0 = deterministic, 2.0 = very creative
# Recommend keeping at 0 for consistent reviews
REVIEWSTEM_TEMPERATURE=0

# -------------------- Resource Limits --------------------

# Maximum characters to include from git diff
# Default: 12000
# Larger diffs will be truncated to this limit
# Increase for large PRs, decrease to save tokens
REVIEWSTEM_DIFF_LIMIT=12000

# Maximum number of files to include in repository map
# Default: 150
# Repository map provides context about project structure
# Increase for large codebases, decrease to save tokens
REVIEWSTEM_REPO_MAP_MAX_FILES=150

# Maximum characters to read from a single file via read_file tool
# Default: 8000
# Reviewers can read files for context during review
# Increase for large files, decrease to save tokens
REVIEWSTEM_FILE_READ_LIMIT=8000

# -------------------- Cross-Session Evolution --------------------

# Minimum fitness score required to record a genome as a candidate skill
# Default: 0.85
# REVIEWSTEM_LEARN_THRESHOLD=0.85

# Number of corroborating successful reviews before a candidate is promoted
# to a learned skill (and starts participating in retrieval)
# Set to 1 to disable the candidate tier (old single-success behaviour)
# Default: 2
# REVIEWSTEM_CANDIDATE_PROMOTIONS=2

# Promoted skills below this success rate (after MIN_USAGE) are eligible
# for pruning via `reviewstem skills prune`
# Default: 0.5
# REVIEWSTEM_PRUNE_MIN_SUCCESS_RATE=0.5

# Minimum number of uses before a promoted skill can be pruned
# Default: 3
# REVIEWSTEM_PRUNE_MIN_USAGE=3

# -------------------- OpenSpace MCP Integration --------------------

# OpenSpace MCP server provides skill search and retrieval
# Install: git clone https://github.com/HKUDS/OpenSpace.git && cd OpenSpace && pip install -e .
# Verify: python -m openspace.mcp_server --help

# LLM API Key for OpenSpace (choose one):

# Option 1: Use OpenAI (works with existing OpenAI key)
# Uses the same OPENAI_API_KEY as ReviewStem
# OPENSPACE_MODEL=gpt-4o

# Option 2: Use Anthropic (for Claude models)
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENSPACE_MODEL=anthropic/claude-sonnet-4.5

# Option 3: Use OpenRouter (access Claude with OpenAI-style API)
# Get your key from: https://openrouter.ai/
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENSPACE_MODEL=openrouter/anthropic/claude-sonnet-4.5

# OpenSpace Cloud API key (optional, for community skill sharing)
# Get your key from: https://open-space.cloud
# OPENSPACE_API_KEY=sk-openspace-your_key_here

# OpenSpace workspace directory (optional)
# Default: current directory
# OPENSPACE_WORKSPACE=/path/to/workspace

# Host skill directories (optional, comma-separated on Windows, colon-separated on Unix)
# Default: ./skills
# OPENSPACE_HOST_SKILL_DIRS=/path/to/ReviewStem/skills

# Enable OpenSpace skill recording (optional)
# Default: true
# OPENSPACE_ENABLE_RECORDING=true
