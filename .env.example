# ============================================
# ReviewStem Configuration
# ============================================

# -------------------- Required --------------------

# OpenAI API key for LLM access
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# -------------------- Optional --------------------

# OpenAI model to use for reviews
# Default: gpt-4o-mini
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Note: Larger models provide better quality but cost more
# REVIEWSTEM_MODEL=gpt-4o-mini

# -------------------- Iteration Control --------------------

# Maximum number of mutation iterations per review
# Default: 2
# Range: 1-10
# Higher values allow more refinement but increase API costs
REVIEWSTEM_MAX_ITERATIONS=2

# Target fitness score to stop iteration early
# Default: 0.90
# Range: 0.0-1.0
# Reviews achieving this score will stop iterating early
REVIEWSTEM_TARGET_SCORE=0.90

# LLM temperature for review generation
# Default: 0
# Range: 0.0-2.0
# 0 = deterministic, 2.0 = very creative
# Recommend keeping at 0 for consistent reviews
REVIEWSTEM_TEMPERATURE=0

# -------------------- Resource Limits --------------------

# Maximum characters to include from git diff
# Default: 12000
# Larger diffs will be truncated to this limit
# Increase for large PRs, decrease to save tokens
REVIEWSTEM_DIFF_LIMIT=12000

# Maximum number of files to include in repository map
# Default: 150
# Repository map provides context about project structure
# Increase for large codebases, decrease to save tokens
REVIEWSTEM_REPO_MAP_MAX_FILES=150

# Maximum characters to read from a single file via read_file tool
# Default: 8000
# Reviewers can read files for context during review
# Increase for large files, decrease to save tokens
REVIEWSTEM_FILE_READ_LIMIT=8000
